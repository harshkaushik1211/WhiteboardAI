# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_LINE_ART_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_SIZE=1536x1024

# Enhanced stroke: vision bboxes → contour → SVG paths (no SAM3)
STROKE_BACKEND=vision_contour
SEGMENTATION_VISION_MODEL=gpt-4o-mini
VISION_MAX_OBJECTS=5
VISION_BBOX_PADDING=0.08
VISION_IMAGE_MAX_SIDE=768
SCENE_IMAGE_CONCURRENCY=3
CONTOUR_CANNY_LOW=40
CONTOUR_CANNY_HIGH=120
CONTOUR_MIN_AREA=25

# Server
PORT=8000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Paths
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
GENERATED_DIR=generated
ASSETS_DIR=assets

# Remotion
RENDERER_DIR=renderer
REMOTION_CONCURRENCY=4
